# Wallet Connection Configuration
# ================================
# WalletConnect Project ID (required for EVM wallet connections via WalletConnect)
# Obtain from: https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Etherscan V2 API Key Configuration
# ================================
# Etherscan V2 unified API key (required for EVM contract ABI auto-fetching)
# The EVM adapter uses this key via AppConfigService to fetch verified contract ABIs
# Obtain from: https://etherscan.io/apis
VITE_APP_CFG_SERVICE_ETHERSCANV2_API_KEY=your_etherscan_v2_api_key_here

# Google Analytics Configuration
# ================================
# Google Analytics Measurement ID for tracking user interactions
# Staging: G-9PR17V0MCP, Production: G-E0ZEWRWW06
VITE_GA_TAG_ID=

# Optional local development flags (never enable in production builds)
# ====================================================================
# Dev Tools menu (mainnet seed helpers, network error triggers):
# VITE_APP_CFG_FEATURE_FLAG_SHOW_DEV_TOOLS=true
#
# Override mainnet disable policy when testing self-hosted behavior locally:
# VITE_APP_CFG_FEATURE_FLAG_MAINNET_NETWORKS_DISABLED=false
